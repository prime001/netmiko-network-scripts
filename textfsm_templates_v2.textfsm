The existing scripts cover port bounce, config rollback, firmware check, change validation, multi-vendor runner, device discovery, health check, config deploy, TextFSM templates, and show command parsing. A MAC address tracer (resolves IP→MAC via ARP table, then MAC→port via MAC address table) fills a real gap and is a genuinely useful network troubleshooting tool.

```python
"""
mac_tracer.py - Trace a MAC or IP address to its switch port.

Connects to a network device, optionally resolves a target IP to a MAC via the
ARP table, then searches the MAC address table to identify which switch port
the host is connected to. Flags uplink/trunk ports so operators know to follow
the chain to adjacent switches.

Usage:
    python mac_tracer.py --device 192.168.1.1 --username admin --password secret \
        --target 00:1A:2B:3C:4D:5E

    python mac_tracer.py --device 192.168.1.1 --username admin --password secret \
        --target-ip 10.0.0.50 --device-type cisco_ios

Prerequisites:
    - Python 3.9+
    - netmiko >= 4.0  (pip install netmiko)
    - SSH access with privilege to run 'show mac address-table' and 'show ip arp'
"""

import argparse
import logging
import re
import sys
from typing import Optional

from netmiko import ConnectHandler
from netmiko.exceptions import NetmikoAuthenticationException, NetmikoTimeoutException

logging.basicConfig(format="%(asctime)s [%(levelname)s] %(message)s", level=logging.INFO)
logger = logging.getLogger(__name__)

UPLINK_PATTERNS = [
    re.compile(r"^Te", re.IGNORECASE),
    re.compile(r"^Fo", re.IGNORECASE),
    re.compile(r"^Hu", re.IGNORECASE),
    re.compile(r"^Po", re.IGNORECASE),
    re.compile(r"^Gi\d+/\d+/\d+", re.IGNORECASE),
]


def normalize_mac(mac: str) -> str:
    clean = re.sub(r"[:\-\.]", "", mac).lower()
    if len(clean) != 12:
        raise ValueError(f"Invalid MAC address: {mac!r}")
    return ":".join(clean[i : i + 2] for i in range(0, 12, 2))


def to_cisco_mac(mac: str) -> str:
    clean = mac.replace(":", "")
    return f"{clean[0:4]}.{clean[4:8]}.{clean[8:12]}"


def resolve_ip_to_mac(conn, ip: str) -> Optional[str]:
    output = conn.send_command("show ip arp")
    pattern = re.compile(
        rf"Internet\s+{re.escape(ip)}\s+\S+\s+(\S+)\s+ARPA", re.IGNORECASE
    )
    match = pattern.search(output)
    if not match:
        return None
    raw = match.group(1).replace(".", "")
    try:
        return normalize_mac(raw)
    except ValueError:
        return None


def query_mac_table(conn, mac: str, device_type: str) -> list[dict]:
    cisco_mac = to_cisco_mac(mac)

    if "juniper" in device_type:
        cmd = f"show ethernet-switching table | match {cisco_mac}"
    else:
        cmd = f"show mac address-table address {cisco_mac}"

    output = conn.send_command(cmd)
    entries = []

    # Cisco IOS/IOS-XE: VLAN  MAC-Address  Type  Ports
    for match in re.finditer(
        r"(\d+)\s+" + re.escape(cisco_mac) + r"\s+\S+\s+(\S+)",
        output,
        re.IGNORECASE,
    ):
        entries.append({"vlan": match.group(1), "mac": mac, "port": match.group(2)})

    return entries


def is_uplink(port: str) -> bool:
    return any(p.match(port) for p in UPLINK_PATTERNS)


def trace(
    host: str,
    username: str,
    password: str,
    device_type: str,
    ssh_port: int,
    target_mac: Optional[str],
    target_ip: Optional[str],
) -> None:
    params = {
        "device_type": device_type,
        "host": host,
        "username": username,
        "password": password,
        "port": ssh_port,
    }

    logger.info("Connecting to %s (%s)", host, device_type)
    try:
        with ConnectHandler(**params) as conn:
            hostname = conn.find_prompt().rstrip("#>")
            logger.info("Connected to %s", hostname)

            mac = target_mac
            if target_ip and not mac:
                logger.info("Resolving %s via ARP table", target_ip)
                mac = resolve_ip_to_mac(conn, target_ip)
                if not mac:
                    logger.error("Could not resolve %s to a MAC address in ARP table", target_ip)
                    sys.exit(1)
                logger.info("Resolved %s -> %s", target_ip, mac)

            mac = normalize_mac(mac)
            logger.info("Searching MAC address table for %s", mac)
            entries = query_mac_table(conn, mac, device_type)

            if not entries:
                logger.warning("MAC %s not found on %s", mac, hostname)
                sys.exit(0)

            print(f"\nResults from {hostname} ({host}):")
            print(f"{'VLAN':<8}{'MAC Address':<20}{'Port':<22}Note")
            print("-" * 68)
            for e in entries:
                note = "uplink — follow to next switch" if is_uplink(e["port"]) else "access port"
                print(f"{e['vlan']:<8}{e['mac']:<20}{e['port']:<22}{note}")
            print()

    except NetmikoAuthenticationException:
        logger.error("Authentication failed for %s@%s", username, host)
        sys.exit(1)
    except NetmikoTimeoutException:
        logger.error("Connection timed out to %s", host)
        sys.exit(1)
    except Exception as exc:
        logger.error("Unexpected error: %s", exc)
        raise


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Trace a MAC or IP address to its switch port via netmiko."
    )
    parser.add_argument("--device", required=True, help="Switch IP or hostname")
    parser.add_argument("--username", required=True, help="SSH username")
    parser.add_argument("--password", default="", help="SSH password")
    parser.add_argument("--device-type", default="cisco_ios", help="Netmiko device type")
    parser.add_argument("--port", type=int, default=22, help="SSH port (default: 22)")
    parser.add_argument("--debug", action="store_true", help="Enable debug logging")

    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("--target", metavar="MAC", help="MAC address to trace")
    group.add_argument("--target-ip", metavar="IP", help="IP address to resolve then trace")

    args = parser.parse_args()

    if args.debug:
        logging.getLogger().setLevel(logging.DEBUG)

    mac = None
    if args.target:
        try:
            mac = normalize_mac(args.target)
        except ValueError as exc:
            logger.error("%s", exc)
            sys.exit(1)

    trace(
        host=args.device,
        username=args.username,
        password=args.password,
        device_type=args.device_type,
        ssh_port=args.port,
        target_mac=mac,
        target_ip=args.target_ip,
    )


if __name__ == "__main__":
    main()
```